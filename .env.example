# Copy this file to `.env` and adjust values as needed.
# Docker Compose uses these variables directly.
# For local `dotnet run`, change `Host=postgres/minio/redis` to `Host=localhost`.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=latex_renderer

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# App
ConnectionStrings__DefaultConnection=Host=postgres;Database=latex_renderer;Username=postgres;Password=postgres
Minio__Endpoint=minio:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=minioadmin
Redis__ConnectionString=redis:6379

# OAuth (optional; leave empty to disable external login providers)
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=
Authentication__GitHub__ClientId=
Authentication__GitHub__ClientSecret=
